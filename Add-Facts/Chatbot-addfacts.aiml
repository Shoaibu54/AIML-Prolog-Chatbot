  <!--"show facts"-->

  <category>
    <pattern>SHOW FACTS</pattern>
    <template>
      <think>
        <set name="type">showfacts</set>
      </think>
      Okay, let me show you the current facts in the knowledge base.
    </template>
  </category>

  <category>
    <pattern>LIST FACTS</pattern>
    <template><srai>SHOW FACTS</srai></template>
  </category>

  <category>
    <pattern>WHAT FACTS DO YOU KNOW</pattern>
    <template><srai>SHOW FACTS</srai></template>
  </category>

</aiml>
