<?xml version="1.0" encoding="UTF-8"?>
<aiml>

  <!-- "ali is male" -->

  <category>
    <pattern>ADD MALE *</pattern>
    <template>
      <think>
        <set name="type">addfact</set>
        <set name="fact">male</set>
        <set name="p1"><star/></set>
        <set name="p2">none</set>
      </think>
      Got it!
    </template>
  </category>

  <category>
    <pattern>* IS MALE</pattern>
    <template>
      <think>
        <set name="type">addfact</set>
        <set name="fact">male</set>
        <set name="p1"><star/></set>
        <set name="p2">none</set>
      </think>
      Got it!
    </template>
  </category>

  <category>
    <pattern>* IS A MALE</pattern>
    <template>
      <think>
        <set name="type">addfact</set>
        <set name="fact">male</set>
        <set name="p1"><star/></set>
        <set name="p2">none</set>
      </think>
      Got it!
    </template>
  </category>


  <!--"sara is female"-->

  <category>
    <pattern>ADD FEMALE *</pattern>
    <template>
      <think>
        <set name="type">addfact</set>
        <set name="fact">female</set>
        <set name="p1"><star/></set>
        <set name="p2">none</set>
      </think>
      Got it!
    </template>
  </category>

  <category>
    <pattern>* IS FEMALE</pattern>
    <template>
      <think>
        <set name="type">addfact</set>
        <set name="fact">female</set>
        <set name="p1"><star/></set>
        <set name="p2">none</set>
      </think>
      Got it!
    </template>
  </category>

  <category>
    <pattern>* IS A FEMALE</pattern>
    <template>
      <think>
        <set name="type">addfact</set>
        <set name="fact">female</set>
        <set name="p1"><star/></set>
        <set name="p2">none</set>
      </think>
      Got it!
    </template>
  </category>


  <!--"ali was born in 1992"-->

  <category>
    <pattern>ADD DOB * *</pattern>
    <template>
      <think>
        <set name="type">addfact</set>
        <set name="fact">dateofbirth</set>
        <set name="p1"><star/></set>
        <set name="p2"><star index="2"/></set>
      </think>
      Got it!
    </template>
  </category>

  <category>
    <pattern>* WAS BORN IN *</pattern>
    <template>
     <think>
      <set name="type">addfact</set>
      <set name="fact">dateofbirth</set>
      <set name="p1"><star/></set>
      <set name="p2"><star index="2"/></set>
     </think>
     Got it!
    </template>
  </category>

  <category>
    <pattern>DATE OF BIRTH OF * IS *</pattern>
    <template>
      <think>
        <set name="type">addfact</set>
        <set name="fact">dateofbirth</set>
        <set name="p1"><star/></set>
        <set name="p2"><star index="2"/></set>
      </think>
      Got it!
    </template>
  </category>

  <category>
    <pattern>* BORN IN *</pattern>
    <template>
      <think>
        <set name="type">addfact</set>
        <set name="fact">dateofbirth</set>
        <set name="p1"><star/></set>
        <set name="p2"><star index="2"/></set>
      </think>
      Got it!
    </template>
  </category>


